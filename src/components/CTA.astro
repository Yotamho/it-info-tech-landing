---
import { cta } from "@/content/content";
import Button from "./starwind/button/Button.astro";

const { headline, description, button, disclaimer } = cta;
---

<section id="cta" class="relative py-12 sm:py-16 md:py-20 lg:py-24 overflow-hidden">

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="rounded-2xl border border-primary/20 bg-card/50 backdrop-blur-sm p-8 sm:p-12 md:p-16 text-center">
				<!-- Background gradient -->
	<div class="absolute inset-0 -z-10 bg-linear-to-r from-primary via-primary to-secondary opacity-10"></div>
	<div class="absolute inset-0 -z-10 bg-linear-to-t from-background to-transparent"></div>

			<!-- Headline -->
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6 max-w-3xl mx-auto">
				{headline}
			</h2>

			<!-- Description -->
			<p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-8 sm:mb-12 leading-relaxed">
				{description}
			</p>

			<!-- Contact Form -->
			<form 
				name="contact"	
				method="POST"
				data-netlify="true" 
				class="max-w-2xl mx-auto"
				netlify
			>
				<input type="hidden" name="form-name" value="contact" />
				
				<!-- Two Column Grid -->
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
					<!-- Name -->
					<input
						type="text"
						name="name"
						placeholder="שם מלא"
						class="px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
						aria-label="Full name"
						required
						oninvalid="this.setCustomValidity('אנא מלא/י שדה זה')"
						oninput="this.setCustomValidity('')"
					/>
					
					<!-- Company Name -->
					<input
						type="text"
						name="company"
						placeholder="שם החברה"
						class="px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
						aria-label="Company name"
						required
						oninvalid="this.setCustomValidity('בבקשה מלא שדה זה')"
						oninput="this.setCustomValidity('')"
					/>
					
					<!-- Email -->
					<input
						type="email"
						name="email"
						placeholder="your@email.com"
						class="px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
						aria-label="Email address"
						required
						oninvalid="this.setCustomValidity(this.validity.typeMismatch ? 'בבקשה הכנס כתובת דוא״ל תקינה' : 'בבקשה מלא שדה זה')"
						oninput="this.setCustomValidity('')"
					/>
					
					<!-- Phone -->
					<input
						type="tel"
						name="phone"
						placeholder="מס׳ טלפון"
						dir="rtl"
						class="px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
						aria-label="Phone number"
						required
						oninvalid="this.setCustomValidity('בבקשה מלא שדה זה')"
						oninput="this.setCustomValidity('')"
					/>
				</div>
				
				<!-- Subject -->
				<input
					type="text"
					name="subject"
					placeholder="נושא"
					class="w-full px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary mb-4"
					aria-label="Subject"
				/>
				
				<!-- Body / Message -->
				<textarea
					name="body"
					placeholder="ספר לנו על הצורך שלך"
					rows="5"
					class="w-full px-4 py-3 rounded-md border border-input bg-background text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary mb-6 resize-none"
					aria-label="Message body"
				></textarea>
				
				<!-- Submit Button -->
				<div class="flex justify-center">
					<Button type="submit" variant="primary" size="lg">
						{button.label}
					</Button>
				</div>
			</form>

			<!-- Additional Info -->
			<p class="text-sm text-muted-foreground mt-6">
				{disclaimer}
			</p>
		</div>
	</div>
</section>
