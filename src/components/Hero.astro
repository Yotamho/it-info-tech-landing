---
import { hero } from "@/lib/content";
import Button from "./starwind/button/Button.astro";
---

<section id="hero" class="relative overflow-hidden py-12 sm:py-16 md:py-20 lg:py-24">
	<!-- Background gradient -->
	<div class="absolute inset-0 -z-10 bg-linear-to-b from-primary/5 to-background"></div>

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid gap-12 lg:gap-16 lg:grid-cols-2 items-center">
			<!-- Content -->
			<div class="flex flex-col gap-6 sm:gap-8">
				<!-- Headline -->
				<h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight text-foreground">
					{hero.headline}
				</h1>

				<!-- Subheadline -->
				<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed max-w-xl">
					{hero.subheadline}
				</p>

				<!-- CTA Buttons -->
				<div class="flex flex-col sm:flex-row gap-4 pt-2">
					<Button variant="primary" size="lg" href={hero.primaryCta.href}>
						{hero.primaryCta.label}
					</Button>
					<Button variant="ghost" size="lg" href={hero.secondaryCta.href}>
						{hero.secondaryCta.label}
					</Button>
				</div>

				<!-- Trust indicator (optional) -->
				<div class="flex items-center gap-4 pt-4">
					<div class="flex -space-x-2">
						<div class="h-8 w-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xs font-bold border-2 border-background">
							U
						</div>
						<div class="h-8 w-8 rounded-full bg-secondary text-secondary-foreground flex items-center justify-center text-xs font-bold border-2 border-background">
							V
						</div>
						<div class="h-8 w-8 rounded-full bg-info text-info-foreground flex items-center justify-center text-xs font-bold border-2 border-background">
							W
						</div>
					</div>
					<p class="text-sm text-muted-foreground">
						<strong>1,000+</strong> founders validating their ideas
					</p>
				</div>
			</div>

			<!-- Hero Image Placeholder -->
			<div class="relative h-96 sm:h-112 md:h-125 lg:h-150 rounded-2xl overflow-hidden bg-linear-to-br from-primary/20 to-secondary/20 border border-border flex items-center justify-center">
				<div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
					<svg
						class="w-24 h-24 sm:w-32 sm:h-32 text-primary/40"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.5"
							d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
						></path>
					</svg>
					<p class="text-muted-foreground text-center px-4">
						Hero image or video placeholder
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
