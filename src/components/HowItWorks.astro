---
import { howItWorks } from "@/content/content";
import { Card } from "@/components/starwind/card";

const firstRow = howItWorks.items.slice(0, 3);
const secondRow = howItWorks.items.slice(3);
---

<section
	id="how-it-works"
	class="relative overflow-hidden py-12 sm:py-16 md:py-20 lg:py-24"
>
	<!-- Gradient Background -->
	<div class="absolute inset-0 -z-10 bg-linear-to-b from-primary/5 to-background"></div>

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{howItWorks.heading}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{howItWorks.description}
			</p>
		</div>

		<!-- Bento grid -->
		<div class="space-y-6">
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
				{
					firstRow.map((step) => (
						<div class="h-full">
							<Card class="group relative flex h-full flex-col rounded-2xl border bg-background/60 p-6 sm:p-8 shadow-sm transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:z-20">
								<div class="mb-4 flex items-start gap-4">
									{/* <div class="flex-none flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-xl font-bold transition-transform duration-300 group-hover:scale-110">
										{step.number}
									</div> */}

									<h3 class="text-xl sm:text-2xl font-bold text-foreground">
										{step.headline}
									</h3>
								</div>

								<p class="text-muted-foreground leading-relaxed">
									{step.description}
								</p>
							</Card>
						</div>
					))
				}
			</div>

			<div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
				{
					secondRow.map((step) => (
						<div class="h-full">
							<Card class="group relative flex h-full flex-col rounded-2xl border bg-background/60 p-6 sm:p-8 shadow-sm transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:z-20">
								<div class="mb-4 flex items-start gap-4">
									{/* <div class="flex-none flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-xl font-bold transition-transform duration-300 group-over:scale-110">
										{step.number}
									</div> */}

									<h3 class="text-xl sm:text-2xl font-bold text-foreground">
										{step.headline}
									</h3>
								</div>
							</Card>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>